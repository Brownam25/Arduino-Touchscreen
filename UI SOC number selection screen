#include <TFT_eSPI.h>
#include <Wire.h>

// ================= TOUCH =================
#define TOUCH_ADDR 0x38
#define TOUCH_RST 6

// ================= RELAY =================
#define RELAY_PIN 7

TFT_eSPI tft = TFT_eSPI();

// ================= STATES =================
enum Screen {
  MENU,
  SET_SCREEN,
  SELECT_SOC,
  DISCHARGING,
  FINISHED
};

Screen currentScreen = MENU;

// ================= VARIABLES =================
int tens = 3;
int ones = 0;
int targetSOC = 30;

int currentSOC = -1;
int lastDisplayedSOC = -1;

bool buttonPressed = false;

// ================= TEXT =================
void drawCenteredText(String text, int x, int y, int size, uint16_t color) {
  tft.setTextSize(size);
  tft.setTextColor(color, TFT_BLACK); // ✅ FIXED

  int charWidth = 6 * size;
  int charHeight = 8 * size;
  int textWidth = text.length() * charWidth;

  tft.setCursor(x - textWidth / 2, y - charHeight / 2);
  tft.print(text);
}

// ================= SOC READ =================
void readSOC() {
  static String buffer = "";

  while (Serial1.available()) {
    char c = Serial1.read();

    if (c == '\n') {
      if (buffer.startsWith("SOC:")) {
        currentSOC = buffer.substring(4).toInt();
      }
      buffer = "";
    } else {
      buffer += c;
    }
  }
}

// ================= TOUCH =================
bool getTouch(uint16_t &tx, uint16_t &ty) {
  Wire.beginTransmission(TOUCH_ADDR);
  Wire.write(0x02);
  Wire.endTransmission();
  Wire.requestFrom(TOUCH_ADDR, 1);

  if (!Wire.available()) return false;
  if (Wire.read() == 0) return false;

  Wire.beginTransmission(TOUCH_ADDR);
  Wire.write(0x03);
  Wire.endTransmission();
  Wire.requestFrom(TOUCH_ADDR, 4);

  if (Wire.available() != 4) return false;

  uint16_t x = ((Wire.read() & 0x0F) << 8) | Wire.read();
  uint16_t y = ((Wire.read() & 0x0F) << 8) | Wire.read();

  tx = y;
  ty = 320 - x;

  return true;
}

// ================= BUTTON =================
void drawButton(int x, int y, int w, int h, String label, uint16_t color) {
  tft.fillRoundRect(x, y, w, h, 10, color);
  tft.drawRoundRect(x, y, w, h, 10, TFT_WHITE);
  drawCenteredText(label, x + w/2, y + h/2, 2, TFT_BLACK);
}

// ================= DRAW NUMBERS =================
void drawNumbers(int leftX, int rightX, int boxY) {
  tft.fillRect(leftX - 30, boxY + 5, 60, 80, TFT_BLACK);
  tft.fillRect(rightX - 30, boxY + 5, 60, 80, TFT_BLACK);

  drawCenteredText(String(tens), leftX, boxY + 45, 3, TFT_WHITE);
  drawCenteredText(String(ones), rightX, boxY + 45, 3, TFT_WHITE);

  targetSOC = tens * 10 + ones;
}

// ================= SCREENS =================
void drawMenu() {
  tft.fillScreen(TFT_BLACK);
  drawCenteredText("MAIN MENU", 240, 30, 3, TFT_CYAN);
  drawButton(140, 120, 200, 60, "DISCHARGE", TFT_GREEN);
}

void drawSetScreen() {
  tft.fillScreen(TFT_BLACK);
  drawCenteredText("SET TARGET SOC", 240, 30, 3, TFT_CYAN);
  drawCenteredText("Target: " + String(targetSOC) + "%", 240, 120, 3, TFT_WHITE);

  drawButton(140, 180, 200, 50, "SELECT VALUE", TFT_BLUE);
  drawButton(40, 260, 140, 40, "BACK", TFT_RED);
  drawButton(300, 260, 140, 40, "START", TFT_GREEN);
}

void drawSelectSOC() {
  tft.fillScreen(TFT_BLACK);

  int centerX = 240;
  int offset = 70;
  int leftX = centerX - offset;
  int rightX = centerX + offset;
  int boxY = 100;

  drawCenteredText("SET SOC", centerX, 20, 3, TFT_CYAN);

  drawCenteredText("+", leftX, 60, 3, TFT_WHITE);
  drawCenteredText("-", leftX, 240, 3, TFT_WHITE);
  drawCenteredText("+", rightX, 60, 3, TFT_WHITE);
  drawCenteredText("-", rightX, 240, 3, TFT_WHITE);

  drawNumbers(leftX, rightX, boxY);

  drawButton(140, 270, 100, 40, "EXIT", TFT_RED);
  drawButton(260, 270, 100, 40, "SELECT", TFT_GREEN);
}

void drawDischarging() {
  tft.fillScreen(TFT_BLACK);

  drawCenteredText("DISCHARGING", 240, 40, 3, TFT_GREEN);
  drawCenteredText("Target: " + String(targetSOC) + "%", 240, 90, 3, TFT_WHITE);

  lastDisplayedSOC = -1;

  //  BUTTONS (fixed + always visible)
  drawButton(60, 250, 120, 50, "START", TFT_GREEN);
  drawButton(190, 250, 120, 50, "STOP", TFT_RED);
  drawButton(320, 250, 120, 50, "EXIT", TFT_BLUE);
}

void updateSOCDisplay() {
  if (currentSOC != lastDisplayedSOC) {
    tft.fillRect(100, 130, 280, 40, TFT_BLACK);
    drawCenteredText("Current: " + String(currentSOC) + "%", 240, 150, 3, TFT_WHITE);
    lastDisplayedSOC = currentSOC;
  }
}

void drawFinished() {
  tft.fillScreen(TFT_BLACK);
  drawCenteredText("TARGET REACHED", 240, 120, 3, TFT_GREEN);
  drawButton(140, 250, 200, 50, "MENU", TFT_BLUE);
}

// ================= TOUCH HANDLER =================
void handleTouch(uint16_t tx, uint16_t ty) {

  int centerX = 240;
  int offset = 70;
  int leftX = centerX - offset;
  int rightX = centerX + offset;
  int boxY = 100;

  switch (currentScreen) {

    case MENU:
      if (tx > 140 && tx < 340 && ty > 120 && ty < 180) {
        currentScreen = SET_SCREEN;
        drawSetScreen();
      }
      break;

    case SET_SCREEN:
      if (tx > 140 && tx < 340 && ty > 180 && ty < 230) {
        currentScreen = SELECT_SOC;
        drawSelectSOC();
      }
      else if (tx > 300 && ty > 260) {
        digitalWrite(RELAY_PIN, HIGH);
        currentScreen = DISCHARGING;
        drawDischarging();
      }
      else if (tx < 140 && ty > 260) {
        currentScreen = MENU;
        drawMenu();
      }
      break;

    case SELECT_SOC:
      if (tx > leftX - 25 && tx < leftX + 25 && ty > 30 && ty < 90 && tens < 9) {
        tens++; drawNumbers(leftX, rightX, boxY);
      }
      else if (tx > leftX - 25 && tx < leftX + 25 && ty > 200 && ty < 260 && tens > 3) {
        tens--; drawNumbers(leftX, rightX, boxY);
      }
      else if (tx > rightX - 25 && tx < rightX + 25 && ty > 30 && ty < 90 && ones < 9) {
        ones++; drawNumbers(leftX, rightX, boxY);
      }
      else if (tx > rightX - 25 && tx < rightX + 25 && ty > 200 && ty < 260 && ones > 0) {
        ones--; drawNumbers(leftX, rightX, boxY);
      }
      else if (ty > 270) {
        currentScreen = SET_SCREEN;
        drawSetScreen();
      }
      break;

    case DISCHARGING:

      updateSOCDisplay();

      if (tx > 60 && tx < 180 && ty > 250 && ty < 300) {
        digitalWrite(RELAY_PIN, HIGH);
      }
      else if (tx > 190 && tx < 310 && ty > 250 && ty < 300) {
        digitalWrite(RELAY_PIN, LOW);
      }
      else if (tx > 320 && tx < 440 && ty > 250 && ty < 300) {
        digitalWrite(RELAY_PIN, LOW);
        currentScreen = MENU;
        drawMenu();
      }

      if (currentSOC != -1 && currentSOC <= targetSOC) {
        digitalWrite(RELAY_PIN, LOW);
        currentScreen = FINISHED;
        drawFinished();
      }

      break;

    case FINISHED:
      currentScreen = MENU;
      drawMenu();
      break;
  }
}

// ================= SETUP =================
void setup() {
  Serial1.begin(115200);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  pinMode(TOUCH_RST, OUTPUT);
  digitalWrite(TOUCH_RST, LOW);
  delay(10);
  digitalWrite(TOUCH_RST, HIGH);

  Wire.begin();

  tft.init();
  tft.setRotation(1);

  drawMenu();
}

// ================= LOOP =================
void loop() {

  readSOC();

  uint16_t tx, ty;
  if (getTouch(tx, ty)) {
    if (!buttonPressed) {
      buttonPressed = true;
      handleTouch(tx, ty);
    }
  } else {
    buttonPressed = false;
  }
}
