#include <TFT_eSPI.h>
#include <Wire.h>

// =========================
// TOUCH CONFIGURATION
// =========================
#define TOUCH_ADDR 0x38   // I2C address of touch controller
#define TOUCH_RST 6       // Reset pin for touch controller

// =========================
// RELAY CONFIGURATION
// =========================
#define RELAY_PIN 7       // Pin controlling the solid state relay

// =========================
// TFT DISPLAY OBJECT
// =========================
TFT_eSPI tft = TFT_eSPI();

// =========================
// BUTTON SETTINGS
// =========================
// Centered button on 480x320 screen
#define BTN_W 200
#define BTN_H 100
#define BTN_X ((480 - BTN_W) / 2)
#define BTN_Y ((320 - BTN_H) / 2)

// =========================
// STATE VARIABLES
// =========================
bool relayState = false;     // Tracks ON/OFF state of relay
bool buttonPressed = false;  // Prevents multiple triggers from one touch

// =========================
// FUNCTION: drawButton()
// Draws the button based on relay state
// =========================
void drawButton() {

  if (relayState) {
    // Relay is ON → show GREEN button
    tft.fillRect(BTN_X, BTN_Y, BTN_W, BTN_H, TFT_GREEN);
    tft.setTextColor(TFT_BLACK);

    // Label
    tft.drawString("RELAY ON", BTN_X + 40, BTN_Y + 40, 2);

  } else {
    // Relay is OFF → show BLUE button
    tft.fillRect(BTN_X, BTN_Y, BTN_W, BTN_H, TFT_BLUE);
    tft.setTextColor(TFT_WHITE);

    // Label
    tft.drawString("RELAY OFF", BTN_X + 35, BTN_Y + 40, 2);
  }
}

// =========================
// FUNCTION: getTouch()
// Reads touch data over I2C
// Returns true if touch detected
// Outputs mapped screen coordinates
// =========================
bool getTouch(uint16_t &tx, uint16_t &ty) {

  // Ask touch controller how many touch points exist
  Wire.beginTransmission(TOUCH_ADDR);
  Wire.write(0x02);
  Wire.endTransmission();
  Wire.requestFrom(TOUCH_ADDR, 1);

  if (!Wire.available()) return false;

  uint8_t touches = Wire.read();

  // If no touch detected → exit
  if (touches == 0) return false;

  // Read touch coordinates
  Wire.beginTransmission(TOUCH_ADDR);
  Wire.write(0x03);
  Wire.endTransmission();
  Wire.requestFrom(TOUCH_ADDR, 4);

  if (Wire.available() != 4) return false;

  uint16_t x = ((Wire.read() & 0x0F) << 8) | Wire.read();
  uint16_t y = ((Wire.read() & 0x0F) << 8) | Wire.read();

  // Convert raw touch coordinates to screen coordinates
  tx = y;
  ty = 320 - x;

  return true;
}

// =========================
// SETUP
// =========================
void setup() {

  Serial.begin(115200);

  // --- Relay setup ---
  pinMode(RELAY_PIN, OUTPUT);

  // Start with relay OFF (safe state)
  digitalWrite(RELAY_PIN, LOW);

  // --- TFT chip select fix ---
  pinMode(10, OUTPUT);
  digitalWrite(10, HIGH);

  // --- Reset touch controller ---
  pinMode(TOUCH_RST, OUTPUT);
  digitalWrite(TOUCH_RST, LOW);
  delay(10);
  digitalWrite(TOUCH_RST, HIGH);
  delay(200);

  // --- Initialize I2C for touch ---
  Wire.begin();

  // --- Initialize display ---
  tft.init();
  tft.setRotation(1);   // Landscape
  tft.fillScreen(TFT_BLACK);
  tft.setTextFont(2);

  // Draw initial button
  drawButton();
}

// =========================
// LOOP
// =========================
void loop() {

  uint16_t tx, ty;

  // Check if screen is being touched
  if (getTouch(tx, ty)) {

    // Only trigger once per touch (debounce)
    if (!buttonPressed) {
      buttonPressed = true;

      // Check if touch is inside button area
      if (tx > BTN_X && tx < BTN_X + BTN_W &&
          ty > BTN_Y && ty < BTN_Y + BTN_H) {

        // Toggle relay state
        relayState = !relayState;

        // Apply state to physical relay
        if (relayState) {
          digitalWrite(RELAY_PIN, HIGH);  // Turn ON
          Serial.println("Relay ON");
        } else {
          digitalWrite(RELAY_PIN, LOW);   // Turn OFF
          Serial.println("Relay OFF");
        }

        // Update button appearance
        drawButton();
      }
    }

  } else {
    // Reset button press flag when finger is lifted
    buttonPressed = false;
  }

  delay(50);  // Small delay for stability
}
